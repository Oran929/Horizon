{
  "version": "1.0",
  "ai": {
    "provider": "ali",
    "model": "qwen-plus",
    "api_key_env": "DASHSCOPE_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "throttle_sec": 1,
    "languages": ["zh", "en"],
    "analysis_concurrency": 2,
    "enrichment_concurrency": 2
  },
  "sources": {
    "github": [
      {
        "type": "user_events",
        "username": "karpathy",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "vllm-project",
        "repo": "vllm",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "sgl-project",
        "repo": "sglang",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "huggingface",
        "repo": "transformers",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "ollama",
        "repo": "ollama",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "openai",
        "repo": "openai-python",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 40,
      "min_score": 120
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "Latent Space",
        "url": "https://www.latent.space/feed",
        "enabled": true,
        "category": "ai-news"
      },
      {
        "name": "Hugging Face Blog",
        "url": "https://huggingface.co/blog/feed.xml",
        "enabled": true,
        "category": "ai-open-source"
      },
      {
        "name": "GitHub Trending - Daily",
        "url": "https://mshibanami.github.io/GitHubTrendingRSS/daily/all.xml",
        "enabled": true,
        "category": "github-trending"
      },
      {
        "name": "SemiAnalysis",
        "url": "https://newsletter.semianalysis.com/feed",
        "enabled": true,
        "category": "semiconductors"
      },
      {
        "name": "CNBC Finance",
        "url": "https://www.cnbc.com/id/10000664/device/rss/rss.html",
        "enabled": true,
        "category": "finance"
      },
      {
        "name": "CNBC Markets",
        "url": "https://www.cnbc.com/id/15839069/device/rss/rss.html",
        "enabled": true,
        "category": "markets"
      },
      {
        "name": "Yahoo Finance Top Stories",
        "url": "https://finance.yahoo.com/news/rssindex",
        "enabled": true,
        "category": "finance"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 12,
          "min_score": 40
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 12,
          "min_score": 40
        },
        {
          "subreddit": "singularity",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 8,
          "min_score": 80
        }
      ],
      "users": [],
      "fetch_comments": 6
    },
    "telegram": {
      "enabled": true,
      "channels": [
        {
          "channel": "zaihuapd",
          "enabled": true,
          "fetch_limit": 20
        }
      ]
    },
    "twitter": {
      "enabled": false,
      "users": ["karpathy", "sama", "ylecun", "AndrewYNg"],
      "fetch_limit": 20,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 10
    },
    "openbb": {
      "enabled": true,
      "fetch_filings": false,
      "filings_provider": "sec",
      "watchlists": [
        {
          "name": "ai_megacaps",
          "enabled": true,
          "provider": "yfinance",
          "fetch_limit": 20,
          "category": "equities",
          "symbols": ["NVDA", "MSFT", "GOOGL", "META", "AMZN", "TSLA", "AAPL", "AMD", "AVGO", "TSM", "ASML", "ARM"]
        },
        {
          "name": "china_adr_and_etf",
          "enabled": true,
          "provider": "yfinance",
          "fetch_limit": 20,
          "category": "china-markets",
          "symbols": ["BABA", "TCEHY", "PDD", "BIDU", "KWEB", "MCHI", "ASHR"]
        }
      ]
    },
    "ossinsight": {
      "enabled": true,
      "period": "past_24_hours",
      "languages": ["All", "Python", "TypeScript", "Rust", "Jupyter Notebook"],
      "keywords": ["ai", "llm", "agent", "rag", "inference", "model", "cuda", "transformer", "deep-learning"],
      "min_stars": 15,
      "max_items": 30
    },
    "gdelt": {
      "enabled": true,
      "query": "(artificial intelligence OR OpenAI OR NVIDIA OR semiconductor OR Federal Reserve OR earnings OR funds OR A-shares OR Hong Kong stocks)",
      "mode": "ArtList",
      "max_records": 80,
      "timespan": "24h",
      "language": null,
      "country": null,
      "category": "macro-markets"
    },
    "google_news": {
      "enabled": true,
      "query": "AI 行业 热点 OR 基金 动向 OR A股 市场 分析 OR 港股 市场 分析 OR 财报",
      "language": "zh-CN",
      "country": "CN",
      "ceid": "CN:zh-Hans",
      "max_results": 80,
      "category": "china-markets"
    }
  },
  "filtering": {
    "ai_score_threshold": 7.0,
    "time_window_hours": 24,
    "max_items": 24,
    "category_groups": {
      "ai": {
        "name": "AI / ML / Developer Tools",
        "limit": 11,
        "categories": ["ai-news", "ai-tools", "ai-open-source", "github-trending"]
      },
      "finance": {
        "name": "Finance / Markets / Earnings",
        "limit": 9,
        "categories": ["finance", "markets", "equities", "china-markets", "macro-markets", "semiconductors"]
      }
    },
    "default_group": "other",
    "default_group_limit": 4
  },
  "webhook": {
    "enabled": true,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary_and_items",
    "overview_position": "last",
    "platform": "feishu",
    "layout": "collapsible",
    "fallback_layout": "markdown",
    "languages": ["zh"],
    "request_body": {
      "msg_type": "interactive",
      "card": {
        "schema": "2.0",
        "config": {
          "wide_screen_mode": true
        },
        "header": {
          "title": {
            "tag": "plain_text",
            "content": "#{message_title}"
          },
          "template": "blue"
        },
        "body": {
          "elements": [
            {
              "tag": "markdown",
              "content": "#{summary}"
            }
          ]
        }
      }
    },
    "headers": ""
  }
}
